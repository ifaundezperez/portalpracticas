{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",        /* 👈 Esto es clave para que entienda el .js */
    "moduleResolution": "NodeNext", /* 👈 Esto también */
    "allowImportingTsExtensions": false,
    "rewriteRelativeImportExtensions": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/*/"],
  "exclude": ["node_modules"]
}